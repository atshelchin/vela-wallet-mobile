{
  "expo": {
    "name": "vela-wallet",
    "slug": "vela-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "velawallet",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "app.getvela.wallet",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Vela Wallet uses Bluetooth to securely connect with the Vela Connect browser extension.",
        "NSBluetoothPeripheralUsageDescription": "Vela Wallet uses Bluetooth to securely connect with the Vela Connect browser extension.",
        "NSCameraUsageDescription": "Vela Wallet uses the camera to scan QR codes for wallet addresses.",
        "UIBackgroundModes": ["bluetooth-peripheral"]
      }
    },
    "android": {
      "package": "app.getvela.wallet",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_ADVERTISE",
        "BLUETOOTH_CONNECT",
        "CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "./plugins/with-native-modules"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
